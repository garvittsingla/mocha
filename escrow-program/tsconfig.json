{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "../target/types/*": ["./target/types/*"]
    }
  },
  "include": ["tests/**/*.ts", "target/types/**/*.ts"]
}
